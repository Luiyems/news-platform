# .env.example
# Environment variables template for El rayo
# Copy this file to .env and fill in your values

# =======================
# Application Settings
# =======================

# Node environment (production or development)
NODE_ENV=production

# Server port
PORT=3000

# Public URL for generated docs links (use your Render domain in production)
APP_BASE_URL=http://localhost:3000

# Enable/disable Swagger UI endpoint (/api-docs)
ENABLE_SWAGGER=false

# =======================
# Database Configuration
# =======================

# PostgreSQL connection (when using docker-compose, use 'db' as host)
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=news_platform
DB_PORT=5432

# =======================
# RSS Feed Settings (optional)
# =======================

# RSS update schedule is defined in code (default: every 3 hours)
